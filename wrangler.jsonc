{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cursortab-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-22",
  "minify": true,
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  },
  "ratelimits": [
    {
      "name": "WRITE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 200,
        "period": 10
      }
    },
    {
      "name": "READ_LIMITER",
      "namespace_id": "1002",
      "simple": {
        "limit": 60,
        "period": 60
      }
    }
  ]
}
